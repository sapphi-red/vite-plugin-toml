{
  "name": "vite-plugin-toml",
  "version": "0.8.7",
  "description": "A plugin for rollup/vite to import a toml file.",
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "tsdown src/index.ts --dts --format esm --target=node20",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint --cache .",
    "format": "prettier --cache --write .",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sapphi-red/vite-plugin-toml.git"
  },
  "keywords": [
    "vite",
    "rollup",
    "rollup-plugin",
    "toml"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "sapphi-red",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sapphi-red/vite-plugin-toml/issues"
  },
  "homepage": "https://github.com/sapphi-red/vite-plugin-toml#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/sapphi-red"
  },
  "peerDependencies": {
    "rollup": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "toml-eslint-parser": "^1.0.3"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^5.0.0 || ^6.0.0 || ^7.0.0"
    },
    "rolldown": {
      "type": "compatible",
      "versions": "^1.0.0-rc.1"
    }
  },
  "packageManager": "pnpm@10.28.2"
}
